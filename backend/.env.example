# Backend server port
PORT=3000

# Comma-separated list of frontend origins allowed by CORS
# Example: https://doc-query-nu.vercel.app,http://localhost:5173
FRONTEND_URL=

# Keepalive: set to false to disable the internal ping scheduler
KEEPALIVE_ENABLED=true
# Interval in seconds between pings (default 300 = 5 minutes)
KEEPALIVE_INTERVAL_SECONDS=300

# URL the backend will use to ping itself (include /health if needed)
# If not set, defaults to http://localhost:$PORT/health
SELF_URL=

# Chroma docker health endpoint the backend should ping to keep it warm
# Example: http://localhost:8000/health
CHROMA_HEALTH_URL=http://localhost:8000/health

# Chroma collection name used in the app
CHROMA_COLLECTION=documents

# Daily cleanup: reset Chroma collection on a schedule to reclaim space
DAILY_CLEANUP_ENABLED=false
# Default 24 hours
DAILY_CLEANUP_INTERVAL_HOURS=24
# Optional: also clear once when the container starts
DAILY_CLEANUP_ON_STARTUP=false

# --- External API keys / integrations ---
# GROQ: used for LLM + embedding calls in this project
GROQ_API_KEY=

# Pinecone (optional): if you plan to use Pinecone instead of local embeddings
PINECONE_API_KEY=
PINECONE_INDEX=

# Node environment
NODE_ENV=production

# Optional keepalive startup waits (when running Chroma in another container)
# Set to true to have the backend wait for Chroma to respond at CHROMA_HEALTH_URL
KEEPALIVE_WAIT_FOR_CHROMA=true
KEEPALIVE_WAIT_ATTEMPTS=15
KEEPALIVE_WAIT_DELAY_MS=2000
